*.so

# OpenTofu (Terraform-compatible)
infra/.terraform/
infra/api.zip
infra/*.tfstate
infra/*.tfstate.*
infra/cloudns/.terraform/
infra/cloudns/*.tfstate
infra/cloudns/*.tfstate.*
infra/backend-config.hcl
infra/bootstrap/.terraform/
infra/bootstrap/*.tfstate
infra/bootstrap/*.tfstate.*
*.tfvars
!*.tfvars.example
