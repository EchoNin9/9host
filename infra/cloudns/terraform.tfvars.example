# Copy to terraform.tfvars and fill in. Run: tofu apply -var-file=terraform.tfvars
# CloudNS credentials are in AWS Secrets Manager (9host-cloudns) — never put them here.
# domains defaults to main infra output; override if needed:
# domains = ["echo9.net", "echo9.ca"]

# Set to false when zone/records already exist and import fails (e.g. provider priority bug)
# manage_records = false
